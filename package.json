{
  "name": "@lvce-editor/eslint-config",
  "version": "0.0.0-dev",
  "main": "index.js",
  "type": "module",
  "types": "index.d.ts",
  "scripts": {
    "build": "node packages/build/src/build.js",
    "format": "prettier --write .",
    "postinstall": "lerna bootstrap --ci",
    "lint": "eslint . && prettier --check .",
    "test": "lerna run test",
    "type-check": "tsc -b",
    "update-action-versions": "node packages/build/src/updateActionVersions.ts"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/lvce-editor/eslint-config.git"
  },
  "keywords": [
    "eslint-config"
  ],
  "author": "Lvce Editor",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/lvce-editor/eslint-config/issues"
  },
  "homepage": "https://github.com/lvce-editor/eslint-config#readme",
  "description": "Shared ESLint configuration for Lvce Editor projects.",
  "dependencies": {
    "@cspell/eslint-plugin": "10.0.1",
    "@e18e/eslint-plugin": "^0.5.1",
    "@eslint/css": "1.3.0",
    "@eslint/js": "10.0.1",
    "@eslint/json": "2.0.0",
    "@eslint/markdown": "8.0.2",
    "eslint-plugin-jest": "29.15.2",
    "eslint-plugin-n": "18.1.0",
    "eslint-plugin-package-json": "1.3.0",
    "eslint-plugin-perfectionist": "5.9.1",
    "eslint-plugin-sonarjs": "4.0.3",
    "eslint-plugin-unicorn": "67.0.0",
    "eslint-plugin-yml": "3.4.0",
    "typescript-eslint": "8.61.1"
  },
  "peerDependencies": {
    "eslint": "^10"
  },
  "devDependencies": {
    "@lerna/legacy-package-management": "^8.2.4",
    "@types/node": "^24.2.1",
    "eslint": "^10.5.0",
    "lerna": "^8.2.4",
    "prettier": "^3.8.4",
    "typescript": "6.0.3"
  },
  "prettier": {
    "semi": false,
    "singleQuote": true,
    "printWidth": 150
  },
  "jest": {
    "injectGlobals": false,
    "testTimeout": 240000,
    "extensionsToTreatAsEsm": [
      ".ts"
    ],
    "moduleNameMapper": {
      "^(\\.{1,2}/.*)\\.js$": "$1"
    },
    "transform": {
      "^.+\\.tsx?$": [
        "ts-jest",
        {
          "useESM": true
        }
      ]
    },
    "testMatch": [
      "**/test/**/*.test.ts"
    ],
    "modulePathIgnorePatterns": [
      "<rootDir>/fixtures/"
    ]
  }
}
