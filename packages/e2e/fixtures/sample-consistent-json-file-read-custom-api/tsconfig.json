{
  "compilerOptions": {
    "lib": ["esnext"],
    "target": "esnext",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "skipLibCheck": true,
    "noEmit": true,
    "isolatedModules": true,
    "strict": true,
    "composite": true,
    "allowImportingTsExtensions": true,
    "rootDir": "."
  },
  "include": ["src"]
}
