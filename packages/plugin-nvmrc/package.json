{
  "name": "@lvce-editor/eslint-plugin-nvmrc",
  "version": "0.0.0-dev",
  "main": "dist/index.js",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/lvce-editor/eslint-config.git"
  },
  "type": "module",
  "scripts": {
    "test": "node test/index.ts"
  },
  "license": "MIT",
  "description": "Lint .nvmrc files.",
  "dependencies": {
    "semver": "^7.8.5"
  },
  "devDependencies": {
    "@types/jest": "^30.0.0",
    "@types/node": "^22.10.6",
    "@types/semver": "^7.7.1",
    "esbuild": "^0.28.1",
    "eslint": "^10.6.0",
    "execa": "^9.6.1",
    "jest": "^30.4.2",
    "ts-jest": "^29.4.11"
  },
  "jest": {
    "injectGlobals": false,
    "testTimeout": 240000,
    "extensionsToTreatAsEsm": [
      ".ts"
    ],
    "moduleNameMapper": {
      "^(\\.{1,2}/.*)\\.js$": "$1"
    },
    "transform": {
      "^.+\\.tsx?$": [
        "ts-jest",
        {
          "useESM": true
        }
      ]
    },
    "testMatch": [
      "**/test/**/*.test.ts"
    ],
    "modulePathIgnorePatterns": [
      "<rootDir>/fixtures/"
    ]
  }
}
